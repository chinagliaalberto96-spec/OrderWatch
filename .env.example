VITE_ORDERWATCH_ACCESS_CODE=
VITE_USE_MOCK_DATA=false

# In produzione usare sempre Supabase. Legacy e' ammesso solo in sviluppo
# locale con ALLOW_LEGACY_AUTH=true.
VITE_AUTH_MODE=supabase
VITE_MAILBOX_MANAGEMENT_ENABLED=false
# VITE_SUPABASE_URL=https://PROJECT.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Variabili server da configurare su Vercel (e in .env.local per il dev), senza prefisso VITE_.

# Sorgente dati server-side. Default ufficiale: "supabase".
# "airtable" resta solo fallback tecnico/storico.
# DATA_SOURCE=supabase

# Modalita' Airtable (pilota)
# AIRTABLE_API_KEY=
# AIRTABLE_BASE_ID=

# Modalita' Supabase (backend prodotto) — service key, SOLO server-side
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# ENCRYPTION_KEY=64 caratteri hex per cifrare credenziali mailbox
# AUDIT_HASH_KEY=segreto casuale dedicato per gli hash del registro audit
# AUTH_MODE=supabase
# ALLOW_LEGACY_AUTH=false
# APP_ORGANIZATION_SLUG=graphic-center
# MAILBOX_MANAGEMENT_ENABLED=false
# PUBLIC_APP_URL=https://cliente.orderwatch.it

# Provisioning amministrativo di un nuovo cliente (eseguire sempre prima
# senza --execute per controllare l'anteprima):
# node --env-file=.env.local scripts/provision-organization.js \
#   --slug azienda-demo --name "Azienda Demo Srl" \
#   --owner-name "Nome Owner" --owner-email owner@azienda.it \
#   --internal-domains azienda.it
# Per un test tecnico senza inviare inviti reali:
# node --env-file=.env.local scripts/provision-organization.js --temporary-test --execute
