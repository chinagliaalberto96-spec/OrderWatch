# Profilo frontend/build dedicato. Copiare i valori nel progetto Vercel
# separato di Nova Vision quando il deploy verra' autorizzato.
VITE_CUSTOMER_PROFILE=nova-vision
VITE_AUTH_MODE=supabase
VITE_USE_MOCK_DATA=false
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME

# Variabili server-side Vercel (mai prefissate VITE_)
AUTH_MODE=supabase
APP_ORGANIZATION_SLUG=nova-vision
DATA_SOURCE=supabase
PUBLIC_APP_URL=https://DA-DEFINIRE.example
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=REPLACE_SERVER_SIDE_ONLY
ENCRYPTION_KEY=REPLACE_SERVER_SIDE_ONLY
