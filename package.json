{
  "name": "orderwatch-graphic-center-group",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:nova-vision": "VITE_CUSTOMER_PROFILE=nova-vision VITE_AUTH_MODE=supabase vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test:auth": "node --env-file-if-exists=.env.local scripts/test-secure-auth.js",
    "tenant:preview": "node scripts/provision-organization.js",
    "tenant:test": "node scripts/provision-organization.js --temporary-test --execute",
    "platform-admin": "node scripts/provision-platform-admin.js",
    "test:receiving-api": "node --env-file=.env.local scripts/test-receiving-api.js",
    "test:procurement": "node scripts/test-procurement-model.mjs",
    "test:contractwatch": "node --env-file=.env.local scripts/test-contractwatch-foundation.js && node --env-file=.env.local scripts/test-contractwatch-api.js && node --env-file=.env.local scripts/test-contractwatch-sal-billing.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@vitejs/plugin-react": "^5.0.0",
    "imapflow": "^1.0.164",
    "lucide-react": "^0.468.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "globals": "^16.5.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
